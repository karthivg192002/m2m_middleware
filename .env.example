# These are placeholders for local dev only. configuration.ts throws at boot in
# NODE_ENV=production if JWT_SECRET, JWT_REFRESH_SECRET, DB_PASSWORD, or
# ADMIN_PASSWORD_HASH still match the values shown here.

# App
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowlist of frontend origins; never '*'
CORS_ORIGINS=http://localhost:5173

# Middleware DB (completely separate from any main service DB).
# Postgres runs natively on the host here, not via Docker — point this at
# whatever Postgres instance is reachable by IP/hostname (docker-compose.yml
# only runs Redis + the app; bring your own Postgres).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mtm_middleware
DB_USER=postgres
DB_PASSWORD=password

# Redis (session:{jti} holds { apiUrl, upstreamToken }; refresh:{refreshJti} for refresh revocation)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — generate with `openssl rand -base64 48`, do not reuse across environments
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Intercept config — adapt to any main service via env only ──
# Example values below match a main service mounted under a global "/api" prefix
# that itself requires a tenant/institute code on register. Verify against the
# actual target main service before deploying — these vary per backend.
REGISTER_PATH=/api/auth/register
LOGIN_PATH=/api/auth/login
UPSTREAM_REFRESH_PATH=/api/auth/refresh-token
USERNAME_FIELD=email
TENANT_CODE_FIELD=tenantCode
TENANT_NAME_FIELD=tenantName
API_URL_FIELD=apiUrl
FORWARD_TENANT_CODE_AS=instituteCode
UPSTREAM_TOKEN_PATH=data.accessToken
UPSTREAM_REFRESH_TOKEN_PATH=data.refreshToken

# apiUrl SSRF guard — reject loopback/private/link-local hosts unless explicitly allowed (dev only)
ALLOW_PRIVATE_API_URLS=false

# Middleware admin credentials (bootstrap) — ADMIN_PASSWORD_HASH is a bcrypt hash, never plaintext
ADMIN_EMAIL=admin@internal.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_real_bcrypt_hash
